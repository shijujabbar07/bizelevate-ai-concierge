# BizElevate — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored and MUST NOT be committed.
#
# ENVIRONMENT: set to dev | preprod | prod
# This controls which Supabase project, n8n workflows, and VAPI assistant are targeted.
BIZELEVATE_ENV=dev

# ── Supabase ──────────────────────────────────────────────────────────────────
# Use the project matching BIZELEVATE_ENV above.
# See supabase/ENVIRONMENTS.md for the project registry.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n Cloud ─────────────────────────────────────────────────────────────────
# Dev/preprod: use bizelevate1.app.n8n.cloud (workflow name prefix: [DEV] or [STAGING])
# Prod: use the same instance but target production workflows (no prefix)
N8N_API_URL=https://bizelevate1.app.n8n.cloud
N8N_API_KEY=

# ── VAPI ──────────────────────────────────────────────────────────────────────
# Each environment has its own assistant and webhook secret.
VAPI_WEBHOOK_SECRET=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Google Sheets (OAuth handled in n8n credentials UI) ──────────────────────
# GOOGLE_SHEET_ID=

# ── OpenAI (managed in n8n credentials UI) ───────────────────────────────────
# OPENAI_API_KEY=
