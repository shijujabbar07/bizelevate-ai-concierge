ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
# Browser to pull YouTube cookies from (bypasses 403 bot detection)
# Options: edge (default on Windows), chrome, firefox, brave, chromium
YTDLP_BROWSER=edge
# Optional: override the knowledge base path
# KNOWLEDGE_BASE_PATH=/absolute/path/to/knowledge/youtube-research
