      "parameters": {
        "jsCode": "const toolCallId = $input.item.json.toolCallId;\nconst args = $input.item.json.toolArgs || {};\nconst date = args.date || 'your requested date';\nconst time = args.time || 'your requested time';\n\nreturn [{\n  json: {\n    results: [{\n      toolCallId: toolCallId,\n      result: `I've noted your preference for ${date} at ${time}. Our team will contact you to confirm the exact slot. Would you like me to save your details now so we can reach you?`\n    }]\n  }\n}];"
      },
