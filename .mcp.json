{
  "_note": "COMMITTED TEMPLATE — no real secrets here. Copy to .mcp.local.json and fill in real values.",
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "<N8N_API_URL>",
        "N8N_API_KEY": "<N8N_API_KEY>"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"]
    },
    "todoist": {
      "command": "node",
      "args": ["C:/Users/Shiju Jabbar/AppData/Roaming/npm/node_modules/todoist-mcp/dist/index.js"],
      "env": {
        "TODOIST_MCP_API_KEY": "<TODOIST_API_TOKEN>"
      }
    }
  }
}
