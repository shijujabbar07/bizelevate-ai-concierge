      {
        "parameters": {
          "jsCode": "// Merge call data + client config into one context object.\n// All downstream nodes read from $json (or $('Prepare Context').item.json after empty-body writes).\n\nconst call = $('Normalize Twilio Payload').item.json;\n\n// Supabase REST returns arrays â€” handle both array and direct-object shapes\nconst lookupRaw = $('Lookup Client').item.json;\nconst lookup = Array.isArray(lookupRaw) ? lookupRaw[0] : lookupRaw;\n\nconst configRaw = $input.item.json;\nconst config = Array.isArray(configRaw) ? configRaw[0] : configRaw;\n\nif (!lookup || !lookup.client_id) {\n  throw new Error('No phone_number_map entry for callTo: ' + call.callTo);\n}\nif (!config || !config.id) {\n  throw new Error('No client config found for client_id: ' + lookup.client_id);\n}\n\n// Generate a stable UUID for this call_log row â€” used in the tracking URL so\n// we can correlate a booking link click back to the exact call record.\nconst callLogId = require('crypto').randomUUID();\n\n// Tracking base â€” swap to https://book.bizelevate.app once custom domain is configured\nconst TRACKING_BASE = 'https://book.bizelevate.app';\n\n// Build SMS body â€” use tracking redirect (not raw link) so clicks are recorded\nconst hasBookingLink = config.booking_link && config.booking_link.trim().length > 0;\nconst trackingUrl = hasBookingLink ? `${TRACKING_BASE}/${callLogId}` : null;\nconst smsBody = hasBookingLink\n  ? `Hi, we missed your call at ${config.name}. Book here: ${trackingUrl}`\n  : `Hi, we missed your call at ${config.name}. Reply CALL and we will call you back.`;\n\nreturn [{\n  json: {\n    callFrom:    call.callFrom,\n    callTo:      call.callTo,\n    callSid:     call.callSid,\n    callStatus:  call.callStatus,\n    clientId:    lookup.client_id,\n    capability:  lookup.capability,\n    clientName:  config.name,\n    ownerPhone:  config.owner_phone,\n    bookingLink: config.booking_link || null,\n    trackingUrl,\n    callLogId,\n    smsBody,\n    twilioFrom:  call.callTo   // send FROM the number that was called (correct Twilio number per client)\n  }\n}];"
        },
