      "parameters": {
        "jsCode": "// Twilio StatusCallback POSTs form-encoded data\n// n8n parses the body into $json.body (or directly into $json in some versions)\nconst raw = $input.item.json.body || $input.item.json;\n\nconst callFrom     = (raw.From       || raw.from       || '').trim();\nconst callTo       = (raw.To         || raw.to         || '').trim();\nconst callSid      = (raw.CallSid    || raw.callSid    || '').trim();\nconst callStatus   = (raw.CallStatus || raw.callStatus || '').toLowerCase().trim();\nconst callTimestamp = raw.Timestamp  || new Date().toISOString();\n\nreturn [{ json: { callFrom, callTo, callSid, callStatus, callTimestamp } }];"
      },
