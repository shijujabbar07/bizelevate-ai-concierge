      {
        "parameters": {
          "jsCode": "// Merge appointment + client + Twilio number into reply context.\n// Composes the acknowledgement SMS based on intent (confirm vs cancel).\n\nconst apptCtx  = $('Extract Appointment').item.json;\n\nconst clientRaw = $('Fetch Client Config').item.json;\nconst client    = Array.isArray(clientRaw) ? clientRaw[0] : clientRaw;\n\nconst numRaw    = $input.item.json;\nconst numRow    = Array.isArray(numRaw) ? numRaw[0] : numRaw;\nconst twilioFrom = numRow && numRow.phone_number;\n\nif (!client || !client.id) {\n  throw new Error('No client config for client_id: ' + apptCtx.clientId);\n}\nif (!twilioFrom) {\n  throw new Error('No Twilio number for client_id: ' + apptCtx.clientId);\n}\n\nconst tz       = client.timezone || 'Australia/Sydney';\nconst apptDate = new Date(apptCtx.apptDatetime);\nconst dayName  = apptDate.toLocaleDateString('en-AU', { weekday: 'long', timeZone: tz });\nconst timeStr  = apptDate.toLocaleTimeString('en-AU', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: tz });\n\nlet smsBody;\nif (apptCtx.intent === 'cancel') {\n  smsBody = `Hi ${apptCtx.patientName}, your appointment on ${dayName} at ${timeStr} has been cancelled. Please call us to rebook.\\n\\n\\u2013 ${client.name} Team`;\n} else {\n  smsBody = `Thanks ${apptCtx.patientName}, your appointment on ${dayName} at ${timeStr} is confirmed. See you then!\\n\\n\\u2013 ${client.name} Team`;\n}\n\nconst ownerAlert = apptCtx.intent === 'cancel'\n  ? `${apptCtx.patientName} cancelled their ${timeStr} appointment on ${dayName}. Slot is now available.`\n  : null;\n\nreturn [{\n  json: {\n    ...apptCtx,\n    twilioFrom,\n    twilioTo:   apptCtx.from,\n    smsBody,\n    ownerPhone: client.owner_phone || null,\n    ownerAlert,\n    clinicName: client.name,\n    isCancel:   apptCtx.intent === 'cancel'\n  }\n}];"
        },
