        "parameters": {
          "jsCode": "// Safe extraction of appointment from Supabase array response.\n// Returns [] (stops execution) if no active appointment found.\nconst raw  = $input.item.json;\nconst rows = Array.isArray(raw) ? raw : (raw && raw.id ? [raw] : []);\n\nif (!rows[0] || !rows[0].id) {\n  // No active appointment for this phone number — silently drop\n  return [];\n}\n\nconst appt = rows[0];\nreturn [{\n  json: {\n    appointmentId:    appt.id,\n    clientId:         appt.client_id,\n    patientName:      [appt.patient_name, appt.patient_surname].filter(Boolean).join(' '),\n    mobile:           appt.mobile,\n    apptDatetime:     appt.appointment_datetime,\n    from:             $('Detect Intent').item.json.from,\n    to:               $('Detect Intent').item.json.to,\n    intent:           $('Detect Intent').item.json.intent\n  }\n}];"
