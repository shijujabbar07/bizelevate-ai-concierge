        0,
        304
      ],
      "webhookId": "bizelevate-reminder-reply"
    },
    {
      "parameters": {
        "jsCode": "// Twilio inbound SMS POSTs form-encoded data.\n// n8n parses it into $json directly or nested under $json.body.\nconst raw = $input.item.json.body || $input.item.json;\n\nconst from   = (raw.From       || '').trim();\nconst to     = (raw.To         || '').trim();\nconst body   = (raw.Body       || '').trim();\nconst msgSid = (raw.MessageSid || '').trim();\n\nreturn [{ json: { from, to, body, msgSid } }];"
      },
      "id": "normalize-sms",
      "name": "Normalize SMS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "// Classify the SMS body into a reminder reply intent.\n// CONFIRM variants   → 'confirm'\n// CANCEL variants    → 'cancel'\n// Anything else      → 'other' (silently ignored)\nconst body = ($json.body || '').trim().toUpperCase();\n\nlet intent = 'other';\nif (/^CONFIRM$/.test(body)) {\n  intent = 'confirm';\n} else if (/^CANCEL( APPT(OINTMENT)?)?$/.test(body)) {\n  intent = 'cancel';\n}\n\nreturn [{\n  json: {\n    from:   $json.from,\n    to:     $json.to,\n    intent\n  }\n}];"
      },
      "id": "detect-intent",
      "name": "Detect Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "check-actionable-intent",
              "leftValue": "={{ $json.intent }}",
              "rightValue": "other",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
