          "jsCode": "// Classify the SMS body into a reminder reply intent.\n// CONFIRM variants   → 'confirm'\n// CANCEL variants    → 'cancel'\n// Anything else      → 'other' (silently ignored)\nconst body = ($json.body || '').trim().toUpperCase();\n\nlet intent = 'other';\nif (/^CONFIRM$/.test(body)) {\n  intent = 'confirm';\n} else if (/^CANCEL( APPT(OINTMENT)?)?$/.test(body)) {\n  intent = 'cancel';\n}\n\nreturn [{\n  json: {\n    from:   $json.from,\n    to:     $json.to,\n    intent\n  }\n}];"
        },
